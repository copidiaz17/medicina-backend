# ── Base de datos ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cardio
DB_USER=root
DB_PASSWORD=contraseña_segura_aqui

# ── Seguridad ──────────────────────────────────────────────────
# Generá un secret aleatorio: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=reemplaza_con_string_aleatorio_de_64_bytes

# ── API de IA ──────────────────────────────────────────────────
# Obtené tu key en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Servidor ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS — URL del frontend en producción ─────────────────────
FRONTEND_URL=https://tudominio.com

# ── WhatsApp (UltraMsg) — opcional, para recordatorios de turnos ─
# Obtené las credenciales en https://ultramsg.com
ULTRAMSG_INSTANCE=
ULTRAMSG_TOKEN=
